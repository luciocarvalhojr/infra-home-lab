# backend.secret.hcl.example
# Copy to backend.secret.hcl and fill in your values.
# Never commit backend.secret.hcl to version control.

bucket     = "your-terraform-state-bucket"
region     = "us-east-1"
key        = "terraform/state.tfstate"
endpoint   = "http://192.168.0.95:9000"  # your Minio IP
access_key = "YOUR_MINIO_ACCESS_KEY"     # or set AWS_ACCESS_KEY_ID env var
secret_key = "YOUR_MINIO_SECRET_KEY"     # or set AWS_SECRET_ACCESS_KEY env var
